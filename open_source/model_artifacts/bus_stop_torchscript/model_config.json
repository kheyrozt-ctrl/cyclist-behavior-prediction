{
  "package_scope": "skeleton-to-prediction",
  "model_file_type": "TorchScript",
  "raw_video_processing_included": false,
  "training_code_included": false,
  "skeleton_input_note": "66D = 33 keypoints x 2D coordinates (x, y). Keypoint order and coordinate convention must match the training skeleton format.",
  "stage1_output_note": "每个第一阶段模型输出 (logits, feature)。logits 是分类得分，feature 是供第二阶段使用的隐藏特征。",
  "tested_environment": {
    "python": "3.10.19",
    "pytorch": "2.8.0+cu129",
    "cuda": "12.9"
  },
  "stage1": {
    "head": {
      "file": "head_model.pt",
      "input_shape": "[batch, 12, 66]",
      "fps": 12,
      "window_sec": 1.0,
      "logits_shape": "[batch, 3]",
      "feature_dim": 256,
      "classes": [
        "Left_Look",
        "Right_Look",
        "neutral_head"
      ],
      "classes_notes": [
        "头部左看",
        "头部右看",
        "头部无动作"
      ]
    },
    "upper_limb": {
      "file": "upper_model.pt",
      "input_shape": "[batch, 12, 66]",
      "fps": 12,
      "window_sec": 1.0,
      "logits_shape": "[batch, 3]",
      "feature_dim": 192,
      "classes": [
        "Upper_Limb_Left_Rotation",
        "Upper_Limb_Right_Rotation",
        "neutral_upper_limb"
      ],
      "classes_notes": [
        "上肢左偏转",
        "上肢右偏转",
        "上肢无动作"
      ]
    },
    "leg": {
      "file": "leg_model.pt",
      "input_shape": "[batch, 20, 66]",
      "fps": 20,
      "window_sec": 1.0,
      "logits_shape": "[batch, 2]",
      "feature_dim": 192,
      "classes": [
        "Pedaling",
        "neutral_leg"
      ],
      "classes_notes": [
        "腿部踩踏",
        "腿部无动作"
      ]
    }
  },
  "stage2": {
    "file": "stage2_maneuver_model.pt",
    "input_shape": "[batch, 120, 640]",
    "input_note": "Stage2 does not directly take raw skeleton. It expects a 10-second Stage1 feature sequence.",
    "input_note_zh": "第二阶段模型不直接接收原始骨架。它接收10秒的第一阶段隐藏特征序列；暂定",
    "sequence_sec": 10.0,
    "fps": 12,
    "feature_dim": 640,
    "feature_layout": [
      "head_feature_256",
      "upper_feature_192",
      "leg_feature_192"
    ],
    "feature_layout_notes": "640维 = head_feature_256 + upper_feature_192 + leg_feature_192。",
    "logits_shape": "[batch, 3]",
    "classes": [
      "straight",
      "yield",
      "overtake"
    ],
    "classes_notes": [
      "直行",
      "让行",
      "超车/由于仿真中道路结构设置和影响，左右侧超车合并"
    ]
  }
}
